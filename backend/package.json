{
  "name": "booking-app-backend",
  "version": "1.0.0",
  "description": "MERN Stack Booking System for Small Businesses",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node --import ./instrument.js server.js",
    "dev": "nodemon --exec \"node --import ./instrument.js\" server.js",
    "test": "npm run check",
    "check": "node --check server.js && node --check config/whtasappManager.js",
    "env-check": "node scripts/validateEnv.js"
  },
  "keywords": [
    "booking",
    "appointment",
    "mern"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@sentry/node": "^10.64.0",
    "@sentry/profiling-node": "^10.64.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.0",
    "mongoose": "^7.0.0",
    "morgan": "^1.10.1",
    "puppeteer": "^24.42.0",
    "qrcode-terminal": "^0.12.0",
    "socket.io": "^4.8.3",
    "validator": "^13.9.0",
    "whatsapp-web.js": "github:pedroslopez/whatsapp-web.js",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.14"
  }
