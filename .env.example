# Copy this file to .env and fill values before running in production
PORT=5000
NODE_ENV=production

# MongoDB connection string
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.example.mongodb.net/bookingapp?retryWrites=true&w=majority

# Sentry
SENTRY_DSN=

# JWT secret for auth tokens
JWT_SECRET=change-me

# Frontend origin URL for CORS
FRONTEND_URL=http://localhost:3000
